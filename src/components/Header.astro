---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1); // remove first "/"
const sectionHref = (id: string) => (pathname === '/' ? `#${id}` : `/#${id}`);
import { Image } from 'astro:assets';
import logo from '../img/logo.svg';
import iconEmail from '../img/icon-email.svg';
import wordmark from '../img/logo-wordmark.svg';
//import ThemeIcon from '../components/ThemeIcon.astro';
---

<a class="skip-navigation" href="#main-content">Skip to main content</a>

<header id="header">
	<div>
		<div id="logo">
			<a href="/" aria-label="Logo" role="link" aria-label="link to homepage">
				<Image src={logo} class="logo" alt="TradesAdmin logo" />
			</a>
		</div>
		<div id="phone-number">
			<a href="tel:4169861059" class="phone" role="link" aria-label="phone">416 986 1059</a>
			<a href="mailto:hello@tradesadmin.ca" id="email" role="link" aria-label="email"></a>
		</div>
		<nav id="nav-desktop">
			<ul>
				<li>
					<a class={currentPath === 'services/' ? 'active' : ''} href={sectionHref('services-intro')} role="link" aria-label="link to SERVICES section">SERVICES</a>
				</li>
				<li>
					<a class={currentPath === 'pricing/' ? 'active' : ''} href={sectionHref('pricing')} role="link" aria-label="link to pricing section">PRICING</a>
				</li>
				<li class="site-scan">
					<a class={currentPath === 'contact/' ? 'active' : ''} href={sectionHref('contact')} role="link" aria-label="link to site scan and contact section">Site Scan</a>
				</li>
				<li class="insights-link">
					<a class={currentPath === 'insights/' ? 'active' : ''} href="/insights/" role="link" aria-label="link to INSIGHTS section">INSIGHTS <span>→</span></a>
				</li>
			</ul>
		</nav>

		<button class="nav-toggle" id="hamburger" aria-label="Open menu" aria-expanded="false" tabindex="0">
			<span></span>
			<span></span>
		</button>
	</div>
</header>

<div class="overlay-bg" id="mobile-overlay" aria-hidden="true" inert>
	<nav id="nav-mobile" class="mobile-menu" tabindex="-1">
		<ul>
			<li>
				<a class={currentPath === 'services/' ? 'active' : ''} href={sectionHref('services-intro')} role="link" aria-label="link to SERVICES section">SERVICES</a>
			</li>
			<li>
				<a class={currentPath === 'pricing/' ? 'active' : ''} href={sectionHref('pricing')} role="link" aria-label="link to pricing section">PRICING</a>
			</li>
			<li>
				<a class={currentPath === 'testimonials/' ? 'active' : ''} href={sectionHref('testimonials')} role="link" aria-label="link to TESTIMONIALS section">TESTIMONIALS</a>
			</li>
			<li>
				<a class={currentPath === 'contact/' ? 'active' : ''} href={sectionHref('contact')} role="link" aria-label="link to site scan and contact section">Scan Your Website</a>
			</li>
			<li class="insights-link">
				<a class={currentPath === 'insights/' ? 'active' : ''} href="/insights/" role="link" aria-label="link to INSIGHTS section">INSIGHTS <span>→</span></a>
			</li>
			<li>
				<a href="mailto:hello@tradesadmin.ca" class="semibold email" role="link" aria-label="email">hello@tradesadmin.ca</a>
			</li>
			<li>
				<a href="tel:4169861059" class="phone" role="link" aria-label="phone">416 986 1059</a>
			</li>
		</ul>
	</nav>
</div>
