---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1); // remove first "/"
const currentYear = new Date().getFullYear();
import '../styles/form.scss';
import '../styles/footer.scss';
import { Image } from 'astro:assets';
import logo from '../img/logo-icon.svg';
import contact from '../img/google-seo.webp';
import logoFooter from '../img/logo-footer.svg';
import gbp from '../img/gbp-mobile.webp';
---

<section id="contact">
	<div class="container top btm">
		<div class="flex padding-x align-middle">
			<div class="cell small-18 medium-10">
				<div id="form-container trig-fade-right enable-trig">
					<h2>Contact</h2>
					<Image src={gbp} class="contact-mobile trig-target" alt="TradesAdmin Contact" />
					<p class="margin-btm-med intro semibold">For a technical review of your website and search results, fill out and submit the form below.</p>

					<form method="POST" id="form" class="needs-validation" data-astro-reload novalidate>
						<input type="hidden" name="access_key" value="0224cc0e-9b23-4249-9fd9-a41db82e01cb" />
						<input type="checkbox" class="hidden" style="display:none" name="botcheck" />
						<input type="hidden" name="subject" value="Submission from tradesadmin.ca" />

						<div>
							<label for="company" class="visually-hidden">Company Name</label>
							<input type="text" name="company" id="company" placeholder="Company Name *" required="" />
							<span class="helperText">Company Name</span>
							<div class="empty-feedback invalid-feedback">Please provide your company name</div>
						</div>

						<div>
							<label for="url" class="visually-hidden">URL</label>
							<input type="text" name="url" id="url" placeholder="URL *" required="" />
							<span class="helperText">URL</span>
							<div class="empty-feedback invalid-feedback">Please provide your URL</div>
							<div class="invalid-feedback text-red-400 text-sm mt-1">URL must end with .ca or .com</div>
						</div>

						<div>
							<label for="email" class="visually-hidden">Email</label>
							<input type="email" name="email" id="email_address" placeholder="Email *" required />
							<span class="helperText">Email</span>
							<div class="empty-feedback text-red-400 text-sm mt-1">Please provide your email address</div>
							<div class="invalid-feedback text-red-400 text-sm mt-1">Please provide a valid email address</div>
						</div>
						<div>
							<label for="phone" class="visually-hidden">Phone</label>
							<input type="tel" name="phone" id="phone" placeholder="Phone" />
							<span class="helperText">Phone</span>
							<div class="empty-feedback text-red-400 text-sm mt-1">Please provide your phone number</div>
							<div class="invalid-feedback text-red-400 text-sm mt-1">Please provide a valid phone number</div>
						</div>
						<div>
							<label for="details" class="visually-hidden">Details</label>
							<textarea rows="10" name="details" id="details" placeholder="Questions & Comments"></textarea>
							<span class="helperText">Details</span>
						</div>

						<div class="h-captcha" data-theme="light" data-captcha="true"></div>
						<div id="result"></div>
						<button type="submit" class="btn arrow">SUBMIT</button>
					</form>
				</div>
			</div>
			<div class="cell small-18 medium-8 trig-fade-right enable-trig contact-desktop">
				<Image src={gbp} class="trig-target" alt="TradesAdmin Contact" />
			</div>
		</div>
	</div>
</section>

<footer id="site-footer">
	<div class="container top">
		<div class="flex padding-x">
			<div class="cell small-18">
				<Image class="footer-logo" src={logoFooter} alt="TradesAdmin Logo" />
			</div>
		</div>

		<div class="flex padding-x">
			<div class="cell small-18 medium-10">
				<div class="footer-brand">
					<div class="footer-description">
						<p>
							<span class="semibold">TradesAdmin</span> supports small service businesses across the GTA with technical website corrections and accurate local search configuration to ensure contractor websites
							function reliably and are correctly represented in search results.
						</p>
					</div>
				</div>
			</div>

			<!-- Services Section -->
			<div class="cell small-18 medium-8">
				<div class="footer-section">
					<ul class="footer-links">
						<li>
							<a class={currentPath === 'services/' ? 'active' : ''} href="#services" data-astro-reload role="link" aria-label="link to SERVICES section">SERVICES</a>
						</li>
						<li>
							<a class={currentPath === 'services/' ? 'active' : ''} href="#pricing" data-astro-reload role="link" aria-label="link to pricing section">PRICING</a>
						</li>
						<li>
							<a class={currentPath === 'services/' ? 'active' : ''} href="#process" data-astro-reload role="link" aria-label="link to Process section">Process</a>
						</li>
						<li>
							<a class={currentPath === 'services/' ? 'active' : ''} href="#testimonials" data-astro-reload role="link" aria-label="link to TESTIMONIALS section">TESTIMONIALS</a>
						</li>
						<li>
							<a class={currentPath === 'contact/' ? 'active' : ''} href="#contact" data-astro-reload role="link" aria-label="link to contact section">CONTACT</a>
						</li>
					</ul>

					<div class="contact-info">
						<div class="contact-item">
							<svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
								<path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"></path>
							</svg>
							<a href="mailto:hello@tradesadmin.ca">hello@tradesadmin.ca</a>
						</div>
						<div class="contact-item">
							<svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
								<path
									d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"
								></path>
							</svg>
							<a href="tel:4169861059">416 986 1059</a>
						</div>
						<div class="contact-item">
							<svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
								<path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"></path>
							</svg>
							<span>Toronto, Canada</span>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Footer Bottom -->
		<div class="footer-bottom">
			<div class="flex padding-x align-middle">
				<div class="cell small-18">
					<div class="footer-bottom-content">
						<p class="copyright">© {currentYear} TradesAdmin.ca. All rights reserved.</p>
						<!-- <div class="footer-bottom-links">
							<a href="/terms/">Terms</a>
							<a href="/privacy/">Privacy</a>
							<a href="/cookies/">Cookies</a>
						</div> -->
					</div>
				</div>
			</div>
		</div>
	</div>
</footer>

<script src="../scripts/trig.js"></script>
<script src="../scripts/scripts.js"></script>
<!-- <script src="../scripts/lenis.js"></script> -->

<style type="text/scss">
	.invalid-feedback,
	.empty-feedback {
		display: none;
	}
	#result {
		color: #ff5000 !important;
	}

	.was-validated :placeholder-shown:invalid ~ .empty-feedback,
	.was-validated :not(:placeholder-shown):invalid ~ .invalid-feedback {
		display: block;
		font-size: 0.9rem;
		font-family: 'Barlow Semi Condensed', sans-serif;
		margin-bottom: 1.5rem;
		margin-top: -12px;
		text-transform: none;
	}

	.is-invalid,
	.was-validated :invalid {
		border-color: #ff6000;
	}
	.h-captcha iframe {
		width: 100%;
	}
</style>

<script is:inline src="https://web3forms.com/client/script.js" async defer></script>

<script is:inline>
	// Main form logic with comments for clarity
	document.addEventListener('astro:page-load', () => {
		const form = document.getElementById('form');
		const result = document.getElementById('result');

		// Helper: Check if form is valid using native HTML validation
		function isFormValid(form) {
			form.classList.add('was-validated');
			return form.checkValidity();
		}

		// Helper: Check if hCaptcha is completed
		function isCaptchaCompleted(form) {
			const hCaptchaInput = form.querySelector('textarea[name=h-captcha-response]');
			return hCaptchaInput && hCaptchaInput.value;
		}

		// Helper: Submit form data via fetch
		async function submitForm(form, result) {
			const formData = new FormData(form);
			const object = Object.fromEntries(formData);
			const json = JSON.stringify(object);

			result.innerHTML = 'Sending...';
			try {
				const response = await fetch('https://api.web3forms.com/submit', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
						Accept: 'application/json',
					},
					body: json,
				});
				const data = await response.json();
				result.innerHTML = data.message;
			} catch (error) {
				result.innerHTML = 'Something went wrong!';
			}
			form.reset();
			form.classList.remove('was-validated');
			setTimeout(() => {
				result.style.display = 'none';
			}, 5000);
		}

		// Main submit event handler
		form.addEventListener('submit', function (e) {
			e.preventDefault();

			// 1. Validate form fields
			if (!isFormValid(form)) {
				form.querySelectorAll(':invalid')[0].focus();
				return;
			}

			// 1a. Custom URL validation: must contain a dot and a suffix (.ca, .com, .org, etc.) max 3 chars, with or without http(s):// and trailing slash
			const urlInput = form.querySelector('input[name="url"]');
			const urlValue = urlInput.value.trim();
			// Regex: must have a dot, then 2-3 letter suffix (e.g. .ca, .com, .org), optional http(s)://, optional trailing slash
			const urlSuffixPattern = /^(https?:\/\/)?[\w.-]+\.[a-zA-Z]{2,}(\/)?$/;
			if (!urlSuffixPattern.test(urlValue)) {
				result.style.display = 'block';
				result.innerHTML = 'Please provide a valid URL (e.g. tradesadmin.ca, https://tradesadmin.ca, tradesadmin.ca/, https://tradesadmin.ca/).';
				result.style.color = '#dc3545';
				urlInput.focus();
				return;
			}

			// 2. Validate hCaptcha
			if (!isCaptchaCompleted(form)) {
				result.innerHTML = 'Please complete the captcha.';
				result.style.color = '#dc3545';
				return;
			}

			// 3. Submit form if all validations pass
			submitForm(form, result);
		});
	});
</script>
<script is:inline>
	const formCaptcha = document.getElementById('form');

	formCaptcha.addEventListener('submit', function (e) {
		const hCaptcha = formCaptcha.querySelector('textarea[name=h-captcha-response]').value;

		if (!hCaptcha) {
			e.preventDefault();
			result.innerHTML = 'Please complete the captcha.';
			return;
		}
	});
</script>
