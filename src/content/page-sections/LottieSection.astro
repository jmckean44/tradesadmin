---
import { Image } from 'astro:assets';
import technical from '../../img/technical.webp';
---

<div class="lottie" data-lottie-lazy>
	<Image src={technical} alt="Technical SEO animation preview" class="lottie-fallback" loading="lazy" decoding="async" />
	<lottie-player class="lottie-player" src="/seo.json" background="transparent" speed=".4" loop count="10" style="width: 100%; height: 100%; display: none;"></lottie-player>
</div>
