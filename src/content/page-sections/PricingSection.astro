---
import { Image } from 'astro:assets';
import fix from '../../img/icon-audit.webp';
---

<section id="pricing">
	<div class="container">
		<div class="flex padding-x">
			<div class="cell small-18 medium-8">
				<div class="single-issue-container">
					<h2>Pricing</h2>
				</div>
			</div>
			<div class="cell small-18 medium-10">
				<div class="single-issue">
					<h3>Single-Issue Fix</h3>

					<p class="price-desc txt-lrg">For small isolated fixes such as SSL/HTTP errors, broken forms, layout problems, or any single specific technical issue.</p>
					<div class="pricing-amount">
						<span class="price">$150 - $300</span>
					</div>
				</div>
			</div>
		</div>

		<div class="pricing-card">
			<div class="item">
				<h3><a href="#performance" class="underline" role="link" aria-label="link to Performance">Performance Fixes</a></h3>
				<div class="pricing-amount">
					<span class="price">$350 - $600</span>
				</div>
			</div>
			<div class="item">
				<h3><a href="#seo" class="underline" role="link" aria-label="link to Technical SEO & Indexing">Technical SEO & Indexing</a></h3>
				<div class="pricing-amount">
					<span class="price">$350 - $800</span>
				</div>
			</div>
			<div class="item">
				<h3><a href="#structure" class="underline" role="link" aria-label="link to Structural & Functional Corrections">Structural Corrections</a></h3>
				<div class="pricing-amount">
					<span class="price">$600 - $1,200</span>
				</div>
			</div>
			<div class="item">
				<h3><a href="#maintenance" class="underline" role="link" aria-label="link to Monitoring or Maintenance">Monitoring & Maintenance</a></h3>
				<div class="pricing-amount">
					<span class="price"><sup>$</sup>75<em> / month</em></span>
				</div>
			</div>
			<div class="item">
				<h3>Starter Site</h3>
				<div class="pricing-amount">
					<span class="price">$1,000 - $1,900</span>
				</div>
			</div>
			<div class="item">
				<h3>Credential Recovery</h3>
				<div class="pricing-amount">
					<span class="price"><sup>$</sup>75 <em>/ included with larger jobs</em></span>
				</div>
			</div>
		</div>
		<p class="disclaimer">* Cost depends on the site size, technical complexity, and number of issues identified.</p>
	</div>
</section>
