---
import { Image } from 'astro:assets';
import technical from '../../img/technical.webp';
---

<section id="intro">
	<div class="container">
		<h1>Your website may be <span>losing leads.</span></h1>
		<p class="tagline">
			Technical issues: <span class="semibold">detected</span> and <span class="semibold">corrected</span>.
		</p>

		<div id="before-after">
			<div class="review-preview-card mock-scan">
				<div class="review-score-note center">Typical contractor website diagnostic</div>
				<div class="review-score-grid">
					<div class="review-score-item is-poor">
						<div class="review-score-circle" style="--score:40"><span>40</span></div>
						<strong>Performance</strong>
					</div>
					<div class="review-score-item is-poor">
						<div class="review-score-circle" style="--score:45"><span>45</span></div>
						<strong>SEO</strong>
					</div>
					<div class="review-score-item is-average">
						<div class="review-score-circle" style="--score:60"><span>60</span></div>
						<strong>Accessibility</strong>
					</div>
					<div class="review-score-item is-poor">
						<div class="review-score-circle" style="--score:50"><span>50</span></div>
						<strong>Best Practices</strong>
					</div>
				</div>
			</div>

			<br />

			<div class="review-preview-card mock-scan">
				<div class="review-score-note center">Common technical audit results</div>
				<div class="review-score-grid">
					<div class="review-score-item is-good">
						<div class="review-score-circle" style="--score:95"><span>95</span></div>
						<strong>Performance</strong>
					</div>
					<div class="review-score-item is-good">
						<div class="review-score-circle" style="--score:98"><span>98</span></div>
						<strong>SEO</strong>
					</div>
					<div class="review-score-item is-good">
						<div class="review-score-circle" style="--score:99"><span>99</span></div>
						<strong>Accessibility</strong>
					</div>
					<div class="review-score-item is-good">
						<div class="review-score-circle" style="--score:100"><span>100</span></div>
						<strong>Best Practices</strong>
					</div>
				</div>
			</div>
		</div>

		<p class="disclaimer">* Most issues are small technical fixes - not large agency projects.</p>

		<div class="cta"><a class="btn" href="#contact" role="link" aria-label="link to form">CHECK YOUR WEBSITE</a></div>
	</div>
</section>

<style lang="scss">
	@use '../../styles/variables' as var;

	// #before-after {
	// 	margin: 2rem auto 3rem;
	// 	max-width: 1000px;
	// 	display: flex;
	// 	flex-direction: row;
	// }

	.review-score-grid {
		grid-template-columns: repeat(auto-fit, minmax(125px, 1fr));
		margin-bottom: 2rem;
	}

	.review-preview-card {
		max-width: 800px;
	}

	.review-score-circle span {
		font-size: 2rem;
	}
	.review-score-circle {
		height: 80px;
		width: 80px;
	}
	.review-score-circle:before {
		inset: 5px;
	}
	.review-score-note {
		color: var.$theme-clr-dark;
		font-family: var.$font-sans-serif-med;
		font-size: clamp(1.1rem, 1.5vw, 1.25rem);
		margin-top: 1rem;
		margin-bottom: 1rem;
		text-align: center;
	}
	.review-score-item {
		padding: 1.5rem 1rem;
	}
	.review-score-item strong {
		font-size: clamp(1rem, 1.25vw, 1.25rem);
		line-height: 1;
		text-align: center;
	}

	@media (max-width: 600px) {
		#before-after {
			flex-direction: column;
		}
		.review-score-grid {
			grid-template-columns: repeat(2, 1fr);
			grid-template-rows: repeat(2, 1fr);
			gap: 1rem;
		}
		.review-score-circle {
			height: 80px;
			width: 80px;
		}
	}
	@media (max-width: 500px) {
		.review-score-item {
			padding: 1rem;
		}
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', function () {
		// Set data-score for each span to the intended value (from the HTML, not 0)
		document.querySelectorAll('#before-after .review-score-circle').forEach(function (circle: Element) {
			var span = circle.querySelector('span');
			if (span) span.setAttribute('data-score', span.textContent || '');
			(circle instanceof HTMLElement ? circle : null)?.style.setProperty('--score', '0');
			if (span) span.textContent = '0';
		});

		function animateCircles(circles: NodeListOf<Element> | Element[], cb?: () => void) {
			let idx = 0;
			function animateNext() {
				if (idx >= circles.length) {
					if (cb) cb();
					return;
				}
				const circle = circles[idx];
				const span = circle.querySelector('span');
				const target = parseInt((span && span.getAttribute('data-score')) || '0', 10);
				const duration = 350;
				const start = performance.now();
				function animate(now: number) {
					const elapsed = Math.min((now - start) / duration, 1);
					const value = Math.round(elapsed * target);
					(circle instanceof HTMLElement ? circle : null)?.style.setProperty('--score', value.toString());
					if (span) span.textContent = value.toString();
					if (elapsed < 1) {
						requestAnimationFrame(animate);
					} else {
						(circle instanceof HTMLElement ? circle : null)?.style.setProperty('--score', target.toString());
						if (span) span.textContent = target.toString();
						idx++;
						setTimeout(animateNext, 120);
					}
				}
				(circle instanceof HTMLElement ? circle : null)?.style.setProperty('--score', '0');
				if (span) span.textContent = '0';
				requestAnimationFrame(animate as FrameRequestCallback);
			}
			animateNext();
		}

		const beforeCircles: NodeListOf<Element> = document.querySelectorAll('#before-after .review-preview-card.mock-scan:first-child .review-score-circle');
		const afterCircles: NodeListOf<Element> = document.querySelectorAll('#before-after .review-preview-card.mock-scan:last-child .review-score-circle');

		let hasAnimated = false;
		const beforeAfterSection = document.getElementById('before-after');
		if (beforeAfterSection) {
			const observer = new window.IntersectionObserver(
				(entries, obs) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting && !hasAnimated) {
							hasAnimated = true;
							animateCircles(beforeCircles, function () {
								animateCircles(afterCircles);
							});
							obs.disconnect();
						}
					});
				},
				{ threshold: 0.2 },
			);
			observer.observe(beforeAfterSection);
		}
	});
</script>
