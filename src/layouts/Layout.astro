---
export interface Props {
	pageTitle: string;
	pageSiteTitles: string;
}
import '../styles/global.scss';
import '../styles/trig.scss';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const TITLE = 'TRADESADMIN • Technical and Local SEO, Website Performance Audits, Maintenance & Support';
const DESCRIPTION =
	'TradesAdmin delivers structured technical support for small businesses, specializing in indexing fixes, local data accuracy, performance optimization, security enhancements, technical SEO, website audits, troubleshooting, and ongoing maintenance for businesses in Toronto and the GTA.';
const KEYWORDS =
	'TradesAdmin, small business website support, website administration, remote web admin, B2B website services, responsive web design, affordable web support, technical SEO, website support Toronto, website maintenance GTA, technical SEO Toronto, fix broken contact form Toronto, website fixes Toronto, WordPress help Toronto, website troubleshooting GTA, web performance optimization';
const URL = 'https://tradesadmin.ca';
const LOGO = 'https://tradesadmin.ca/logo.svg';

const { pageTitle } = Astro.props as Props;
const path = Astro.url.pathname;
const pageSiteTitle = path === '/' ? `${TITLE}` : `${pageTitle} | ${TITLE}`;

import { ClientRouter } from 'astro:transitions';
---

<html lang="en" dir="ltr" class="light lenis">
	<head>
		<meta charset="UTF-8" />
		<meta http-equiv="x-ua-compatible" content="ie=edge" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#3a3a42" />
		<meta name="msapplication-navbutton-color" content="#3a3a42" />
		<meta name="apple-mobile-web-app-status-bar-style" content="#3a3a42" />
		<meta name="msapplication-TileColor" content="#3a3a42" />
		<meta name="msapplication-config" content="img/browserconfig.xml" />
		<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
		<meta name="description" content={DESCRIPTION || ''} />
		<meta name="keywords" content={KEYWORDS} />
		<link rel="canonical" href="https://tradesadmin.ca" />
		<title>{pageSiteTitle}</title>

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={pageSiteTitle} />
		<meta property="og:description" content={DESCRIPTION} />
		<meta property="og:url" content="https://tradesadmin.ca{path}" />
		<meta property="og:image" content={LOGO} />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageSiteTitle} />
		<meta name="twitter:description" content={DESCRIPTION} />
		<meta name="twitter:image" content={LOGO} />

		<!-- FAVICONS -->
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="TradesAdmin" />
		<link rel="manifest" href="/site.webmanifest" />

		<!-- Accessibility: skip to content -->
		<style>
			.skip-link {
				position: absolute;
				left: -999px;
				top: auto;
				width: 1px;
				height: 1px;
				overflow: hidden;
				z-index: 100;
				background: #222;
				color: #fff;
				padding: 8px 16px;
				border-radius: 4px;
			}
			.skip-link:focus {
				left: 8px;
				top: 8px;
				width: auto;
				height: auto;
				outline: 2px solid #fff;
			}
		</style>

		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "LocalBusiness",
				"name": "TradesAdmin",
				"url": "https://tradesadmin.ca",
				"image": "https://tradesadmin.ca/assets/logo.png",
				"description": "Technical website support for HVAC, plumbing, electrical, roofing, and service contractors across Toronto and the GTA.",
				"address": {
					"@type": "PostalAddress",
					"addressLocality": "Toronto",
					"addressRegion": "ON",
					"addressCountry": "CA"
				},
				"telephone": "+1-416-986-1059",
				"email": "hello@tradesadmin.ca",
				"areaServed": ["Toronto", "GTA", "Etobicoke", "Scarborough", "North York", "Mississauga", "Brampton", "Vaughan", "Markham", "Richmond Hill"],
				"sameAs": []
			}
		</script>

		<!-- JSON-LD  -->
		<script is:inline type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "Service",
				"serviceType": "Technical Website Support for Contractors",
				"logo": "https://tradesadmin.ca/logo.svg",
				"description": "TradesAdmin delivers structured technical support for small businesses, specializing in indexing fixes, local data accuracy, performance optimization, security enhancements, technical SEO, website audits, troubleshooting, and ongoing maintenance for businesses in Toronto and the GTA.",
				"provider": {
					"@type": "Organization",
					"name": "TradesAdmin",
					"url": "https://tradesadmin.ca"
				},
				"areaServed": "Toronto and the Greater Toronto Area",
				"hasOfferCatalog": {
					"@type": "OfferCatalog",
					"name": "Contractor Technical Services",
					"itemListElement": [
						{
							"@type": "Offer",
							"itemOffered": {
								"@type": "Service",
								"name": "Technical & Local SEO Cleanup"
							}
						},
						{
							"@type": "Offer",
							"itemOffered": {
								"@type": "Service",
								"name": "Performance Optimization"
							}
						},
						{
							"@type": "Offer",
							"itemOffered": {
								"@type": "Service",
								"name": "Structural Cleanup"
							}
						},
						{
							"@type": "Offer",
							"itemOffered": {
								"@type": "Service",
								"name": "Website Maintenance Plans"
							}
						},
						{
							"@type": "Offer",
							"itemOffered": {
								"@type": "Service",
								"name": "Hosting, DNS & SSL Support"
							}
						}
					]
				}
			}
		</script>

		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-ES0ZCH7R7T"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag() {
				dataLayer.push(arguments);
			}
			gtag('js', new Date());

			gtag('config', 'G-ES0ZCH7R7T');
		</script>

		<ClientRouter />
	</head>
	<body>
		<a href="#main-content" class="skip-link">Skip to main content</a>
		<Header />
		<main id="main-content" tabindex="-1" role="main">
			<slot />
		</main>
		<Footer />
	</body>
</html>
