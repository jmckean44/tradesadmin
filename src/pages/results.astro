---
import Layout from '../layouts/Layout.astro';
import '../styles/page-results.scss';
---

<Layout pageTitle="Scan Results" pageSiteTitles="">
	<section id="scan-results">
		<div class="container page-top btm">
			<div class="flex padding-x">
				<div class="cell small-18">
					<div class="results-intro">
						<h1 class="center">Scan Results</h1>
						<p class="center txt-lrg">
							This is a <span class="semibold">preview of how <span id="results-url">[url]</span> <span class="underline">performing</span></span>, followed by a short list of recommendations.
						</p>
						<p class="center txt-lrg">
							To discuss what could be improved in more detail, call <br /><span class="semibold"
								><a href="tel:4169861059" class="underline" role="link" aria-label="link to 416-986-1059">416 986 1059</a></span
							> or email <span class="semibold"
								><a class="underline" href="mailto:hello@tradesadmin.ca?subject=Question about my website" role="link" aria-label="Email Trades Admin">hello@tradesadmin.ca</a></span
							>
						</p>
					</div>
				</div>
			</div>
			<div id="results-root"></div>
		</div>
		<div class="results-cta">
			<p class="center txt-lrg">
				To discuss what could be improved in more detail, call <br /><span class="semibold"
					><a href="tel:4169861059" class="underline" role="link" aria-label="link to 416-986-1059">416 986 1059</a></span
				> or email <span class="semibold"
					><a class="underline" href="mailto:hello@tradesadmin.ca?subject=Question about my website" role="link" aria-label="Email Trades Admin">hello@tradesadmin.ca</a></span
				>
			</p>
		</div>
	</section>

	<script is:inline>
		document.addEventListener('astro:page-load', () => {
			const root = document.getElementById('results-root');
			if (!root) return;

			function parseScore(value) {
				if (value === null || value === undefined || value === '') return null;
				const parsed = Number(value);
				return Number.isFinite(parsed) ? parsed : null;
			}

			function escapeHtml(value) {
				return String(value ?? '')
					.replaceAll('&', '&amp;')
					.replaceAll('<', '&lt;')
					.replaceAll('>', '&gt;')
					.replaceAll('"', '&quot;')
					.replaceAll("'", '&#39;');
			}

			function parseMetricNumber(metric, rawValue) {
				if (rawValue === null || rawValue === undefined || rawValue === '') return null;
				const normalized = String(rawValue).toLowerCase().replace(/,/g, '').trim();
				const match = normalized.match(/-?\d*\.?\d+/);
				if (!match) return null;
				const number = Number(match[0]);
				if (!Number.isFinite(number)) return null;

				if (metric === 'cls') return number;
				if (metric === 'tbt') {
					if (normalized.includes('s') && !normalized.includes('ms')) return number * 1000;
					return number;
				}

				if (metric === 'lcp' || metric === 'interactive') {
					if (normalized.includes('ms')) return number / 1000;
					return number;
				}

				return null;
			}

			function classifyVital(metric, rawValue) {
				const numericValue = parseMetricNumber(metric, rawValue);
				if (numericValue === null) {
					return { status: 'is-na', label: 'N/A' };
				}

				if (metric === 'lcp') {
					if (numericValue <= 2.5) return { status: 'is-good', label: 'Good' };
					if (numericValue <= 4) return { status: 'is-average', label: 'Needs Improvement' };
					return { status: 'is-poor', label: 'Poor' };
				}

				if (metric === 'tbt') {
					if (numericValue <= 200) return { status: 'is-good', label: 'Good' };
					if (numericValue <= 600) return { status: 'is-average', label: 'Needs Improvement' };
					return { status: 'is-poor', label: 'Poor' };
				}

				if (metric === 'cls') {
					if (numericValue <= 0.1) return { status: 'is-good', label: 'Good' };
					if (numericValue <= 0.25) return { status: 'is-average', label: 'Needs Improvement' };
					return { status: 'is-poor', label: 'Poor' };
				}

				if (metric === 'interactive') {
					if (numericValue <= 3.8) return { status: 'is-good', label: 'Good' };
					if (numericValue <= 7.3) return { status: 'is-average', label: 'Needs Improvement' };
					return { status: 'is-poor', label: 'Poor' };
				}

				return { status: 'is-na', label: 'N/A' };
			}

			function vitalCard(metric, label, value) {
				const shown = value ? escapeHtml(value) : 'N/A';
				const classification = classifyVital(metric, value);
				return `
					<div class="review-vital-card ${classification.status}">
						<p class="review-vital-label">${label}</p>
						<p class="review-vital-value">${shown}</p>
						<p class="review-vital-status">${classification.label}</p>
					</div>
				`;
			}

			function scoreRow(label, value) {
				const hasValue = typeof value === 'number' && Number.isFinite(value);
				const safeValue = hasValue ? Math.max(0, Math.min(100, value)) : 0;
				const shown = hasValue ? `${safeValue}` : 'N/A';
				const scoreClass = hasValue && safeValue >= 90 ? 'is-good' : hasValue && safeValue >= 50 ? 'is-average' : hasValue ? 'is-poor' : 'is-na';
				return `
					<div class="review-score-item ${scoreClass}">
						<div class="review-score-circle" style="--score:${safeValue}" role="img" aria-label="${label} score ${shown}">
							<span>${shown}</span>
						</div>
						<strong>${label}</strong>
					</div>
				`;
			}

			function readStoredPayload(key) {
				try {
					const raw = sessionStorage.getItem(key);
					if (raw) {
						const parsed = JSON.parse(raw);
						if (parsed && typeof parsed === 'object') return parsed;
					}
				} catch {
					// no-op
				}

				try {
					const raw = localStorage.getItem(key);
					if (raw) {
						const parsed = JSON.parse(raw);
						if (parsed && typeof parsed === 'object') {
							try {
								sessionStorage.setItem(key, raw);
							} catch {
								// no-op
							}
							return parsed;
						}
					}
				} catch {
					// no-op
				}

				return null;
			}

			function fromBase64Url(value) {
				try {
					const normalized = String(value || '')
						.replace(/-/g, '+')
						.replace(/_/g, '/');
					const padded = normalized + '='.repeat((4 - (normalized.length % 4 || 4)) % 4);
					const binary = atob(padded);
					const utf8 = Array.from(binary)
						.map((char) => `%${char.charCodeAt(0).toString(16).padStart(2, '0')}`)
						.join('');
					return decodeURIComponent(utf8);
				} catch {
					return '';
				}
			}

			function readPayloadFromQueryParam() {
				try {
					const params = new URLSearchParams(window.location.search);
					const encoded = params.get('payload');
					if (!encoded) return null;

					const decoded = fromBase64Url(encoded);
					if (!decoded) return null;

					const parsed = JSON.parse(decoded);
					if (!parsed || typeof parsed !== 'object') return null;

					const normalizedPayload = parsed;
					const serialized = JSON.stringify(normalizedPayload);
					try {
						sessionStorage.setItem('scanResultPayload', serialized);
					} catch {
						// no-op
					}
					try {
						localStorage.setItem('scanResultPayload', serialized);
					} catch {
						// no-op
					}

					params.delete('payload');
					const nextQuery = params.toString();
					const nextUrl = `${window.location.pathname}${nextQuery ? `?${nextQuery}` : ''}${window.location.hash}`;
					window.history.replaceState({}, '', nextUrl);

					return normalizedPayload;
				} catch {
					return null;
				}
			}

			const payload = readStoredPayload('scanResultPayload') || readPayloadFromQueryParam();
			// Populate the URL in the results header if available
			const urlSpan = document.getElementById('results-url');
			if (urlSpan && payload?.preview?.url) {
				urlSpan.textContent = escapeHtml(payload.preview.url);
			} else if (urlSpan) {
				urlSpan.textContent = '[no url]';
			}

			if (!payload?.preview) {
				root.innerHTML = `
					<div class="review-preview-card">
						<h3>No recent scan results found</h3>
						<p class="review-subtitle">Run a new free scan from the homepage to view results here.</p>
						<a href="/#contact" class="btn">Go to Homepage</a>
					</div>
				`;
				return;
			}

			const preview = payload.preview || {};
			const scan = payload.scan || null;
			const notion = payload.notion || null;
			const scores = preview.scores || {};
			const vitals = preview.vitals || {};
			const fixes = Array.isArray(preview.recommendedFixes) ? preview.recommendedFixes : [];
			const unavailableMessageText =
				typeof scan?.error === 'string' && scan.error.trim()
					? scan.error.trim()
					: typeof preview.reviewError === 'string' && preview.reviewError.trim()
						? preview.reviewError.trim()
						: 'Live scan data is currently unavailable. Showing fallback guidance.';
			const reviewUnavailableMessage = preview.available === false ? `<p class="review-subtitle">${escapeHtml(unavailableMessageText)}</p>` : '';

			const scoreHtml = [
				scoreRow('Performance', parseScore(scores.performance)),
				scoreRow('SEO', parseScore(scores.seo)),
				scoreRow('Accessibility', parseScore(scores.accessibility)),
				scoreRow('Best Practices', parseScore(scores.bestPractices)),
			].join('');

			const vitalsHtml = [
				vitalCard('lcp', 'LCP', vitals.lcp),
				vitalCard('tbt', 'TBT', vitals.tbt),
				vitalCard('cls', 'CLS', vitals.cls),
				vitalCard('interactive', 'Interactive', vitals.interactive),
			].join('');

			const fixesHtml = fixes.length ? `<ol>${fixes.map((item) => `<li>${escapeHtml(item)}</li>`).join('')}</ol>` : '<p>No recommended fixes returned.</p>';

			// Remove Notion sync status from .review-subtitle (no placeholder)
			const notionStatusHtml = '';

			root.innerHTML = `
				<div class="review-preview-card">                   
					${preview.available === false ? `<p class="review-subtitle">Live scan data is temporarily unavailable. Recommendations below are based on best practices, not a real-time scan.</p>` : ''}
					<div class="review-score-grid">${scoreHtml}</div>
					<div class="review-vitals">${vitalsHtml}</div>
					<div class="review-fixes">
						<h4>Recommended Fixes</h4>
						${fixesHtml}
					</div>
				</div>
			`;
		});
	</script>
</Layout>
