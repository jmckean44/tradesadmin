---
import Layout from '../layouts/Layout.astro';
---

<Layout pageTitle="404 Not Found" pageSiteTitles="">
	<section id="not-found">
		<div class="container">
			<div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh;">
				<h1 style="font-size: 3rem; margin-bottom: 1rem;">404</h1>
				<p style="font-size: 1.5rem; text-align: center;">Sorry, the page you are looking for does not exist.</p>
				<p style="font-size: 1.5rem; text-align: center;">Go to the <a href="/" class="underline">homepage</a> for more options.</p>
			</div>
		</div>
	</section>
</Layout>
