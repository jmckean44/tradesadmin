---
import Layout from '../../layouts/Layout.astro';
import '../../styles/blog.scss';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

export const prerender = true;

export async function getStaticPaths() {
	const blogPosts = await getCollection('blog');
	return blogPosts.map((post) => ({
		params: { slug: post.slug },
		props: { post },
	}));
}

interface InsightsPostData {
	title: string;
	heroImage?: string;
	date: Date;
	author?: string;
	tags: string[];
	excerpt?: string;
}

interface InsightsPost {
	data: InsightsPostData;
	rendered?: { html: string };
	body?: string;
	slug: string;
}

const { post } = Astro.props as { post: InsightsPost };
---

<Layout pageTitle={post.data.title} pageSiteTitles={`${post.data.title} - Insights`} pageDescription={post.data.excerpt}>
	<article class="insights-post">
		<div class="container">
			<div class="flex padding-x">
				<div class="cell small-18">
					<!-- Post Header -->
					<div class="post-header trig-fade-up enable-trig" data-trig-var="true">
						{
							post.data.heroImage && (
								<div class="post-hero-image trig-target">
									<Image src={post.data.heroImage} alt={post.data.title} inferSize={true} />
								</div>
							)
						}

						<div class="back-to-insights top">
							<a href="/insights/" class="back-btn">← Back to Insights</a>
						</div>

						<!-- <div class="post-meta">
							<time datetime={post.data.date.toISOString()}>
								{
									post.data.date.toLocaleDateString('en-US', {
										year: 'numeric',
										month: 'long',
										day: 'numeric',
									})
								}
							</time>
							{post.data.author && <span class="author">by {post.data.author}</span>}
						</div> -->

						<div class="post-tags">
							{post.data.tags.slice(0, 3).map((tag) => <span class="tag">{tag.trim()}</span>)}
						</div>

						<!-- <h1 class="post-title">{post.data.title}</h1> -->
						<!-- <p class="post-excerpt">{post.data.excerpt}</p> -->
					</div>

					<!-- Post Content -->
					<div class="post-content">
						<div class="markdown-content" set:html={post.rendered?.html || post.body} />
						<script is:inline>
							// Remove first <p> containing only an <img> (including Astro's __astro_image_ attribute) in .markdown-content
							document.addEventListener('DOMContentLoaded', () => {
								const container = document.querySelector('.markdown-content');
								if (!container) return;
								// Find all <p> tags with only one child and that child is an <img>
								const ps = container.querySelectorAll('p');
								for (const p of ps) {
									if (p.childElementCount === 1 && p.firstElementChild.tagName === 'IMG' && p.textContent.trim() === '') {
										p.remove();
										break;
									}
								}
							});
						</script>
					</div>

					<!-- Post Footer -->
					<footer class="post-footer">
						<div class="back-to-insights">
							<a href="/insights/" class="back-btn">← Back to Insights</a>
						</div>
					</footer>
				</div>
			</div>
		</div>
	</article>
</Layout>
